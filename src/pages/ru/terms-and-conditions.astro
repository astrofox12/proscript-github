---
import Layout from "../../layouts/Layout.astro";
import TermsAndConditions from "../../components/TermsAndConditions.jsx";
import { useTranslations } from "../../i18n/utils.js";
import { getRelativeLocaleUrl } from 'astro:i18n';
import { SEO_DATA } from '../../lib/seo.js';
const locale = Astro.currentLocale ?? "en"
const t = useTranslations(locale)
const seo = SEO_DATA[locale]['terms-and-conditions'];
const homeUrl = getRelativeLocaleUrl(locale, '');
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
    <TermsAndConditions client:load t={JSON.stringify(t)} homeUrl={homeUrl} currentLocale={locale} />
</Layout>
