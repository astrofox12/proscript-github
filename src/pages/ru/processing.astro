---
import Layout from "../../layouts/Layout.astro";
import ProcessingPayment from "../../components/ProcessingPayment.jsx";
import { useTranslations } from "../../i18n/utils.js";
import { getRelativeLocaleUrl } from 'astro:i18n';
import { SEO_DATA } from '../../lib/seo.js';
const locale = Astro.currentLocale ?? "ru"
const t = useTranslations(locale)
const seo = SEO_DATA[locale]['payment-processing'];
const homeUrl = getRelativeLocaleUrl(locale, '');
---
<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
    <ProcessingPayment client:load t={JSON.stringify(t)} homeUrl={homeUrl} currentLocale={locale} />
</Layout>
